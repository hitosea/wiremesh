# WireMesh E2E test — server configuration
# Copy this file to servers.env and fill in your values.
# servers.env is gitignored; this template (.example) is checked in.

# All four servers are required. The skill assigns specific roles:
#   A = entry node, WS+TLS Xray (must have a publicly resolvable domain)
#   B = exit + entry (dual role), REALITY Xray
#   C = exit only
#   D = exit only

WIREMESH_A_IP=
WIREMESH_A_DOMAIN=

WIREMESH_B_IP=
WIREMESH_C_IP=
WIREMESH_D_IP=

# SSH credentials (root is required to install services).
# Same credentials are used for all four servers.
WIREMESH_SSH_USER=root
WIREMESH_SSH_PASS=

# Public-facing platform URL — must be reachable from the four servers
# so their Agent processes can pull binaries and submit status reports.
WIREMESH_PLATFORM_URL=

# Local platform URL — used by the test harness on the dev machine.
# Defaults to http://localhost:3456 if unset.
WIREMESH_LOCAL_URL=http://localhost:3456

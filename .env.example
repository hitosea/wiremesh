# Public URL of the management platform (used in one-click install scripts)
PUBLIC_URL=https://your-server-address:3456

# JWT signing key (>=32 chars). Generate: openssl rand -base64 48
JWT_SECRET=

# AES-256-GCM key (64-character hex, i.e. 32 bytes). Generate: openssl rand -hex 32
ENCRYPTION_KEY=
